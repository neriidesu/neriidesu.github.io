---
interface Props {
    title: string
    description: string
    url: string
}

const {title, description, url} = Astro.props
---

<div class="container">
    <h3><a href={url}>{title}</a></h3>
    <p>{description}</p>
</div>

<style lang="scss">
    .container {
        h3 {
            margin: 0px
        }
        p {
            margin: 0px;
            text-align: left;
        }
        width: 50vw;
        padding: 10px;
        margin:10px;
        border: 2px solid #313244;
        border-radius: 4px;
    }
</style>

